{
  "name": "viewfinder",
  "version": "1.4.2",
  "description": "桌面取景框：AI 能看到的那一小块屏幕",
  "main": "main.js",
  "author": "tutusagi",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "check": "node --check main.js && node --check preload.js && node --check game-gateway.js",
    "test": "node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "app.viewfinder.desktop",
    "productName": "取景框",
    "files": [
      "main.js",
      "game-gateway.js",
      "preload.js",
      "frame.html",
      "panel.html",
      "GAME_MCP.md"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "取景框-${version}.exe",
      "signAndEditExecutable": false
    },
    "portable": {
      "requestExecutionLevel": "user"
    }
  }
}
